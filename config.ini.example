[keepa]
api_key =

[files]
input_excel = output.xlsx
output_excel = output_keepa.xlsx
asin_cache = asin_cache.csv

[app]
log_file = keepa_enrich.log
timeout_sec = 30

[run]
default_mode = single
reserve_tokens = 10
tokens_per_minute = 5
interval_seconds = 60
max_minutes = 480
stop_when_tokens_below = 10
max_zero_budget_cycles = 3
max_token_status_failures = 3
